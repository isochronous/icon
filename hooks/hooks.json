{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/inject-manager-role.mjs"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/guardrail-pretooluse.mjs"],
            "bash": "node \"$CLAUDE_PLUGIN_ROOT/hooks/guardrail-pretooluse.mjs\""
          }
        ]
      }
    ]
  }
}
